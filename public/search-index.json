[{"id":"yong-e","title":"咏鹅","author":"骆宾王","dynasty":"唐代","type":"诗","isRequired":true,"text":["鹅，鹅，鹅，","曲项向天歌。","白毛浮绿水，","红掌拨清波。"]},{"id":"chun-xiao","title":"春晓","author":"孟浩然","dynasty":"唐代","type":"诗","isRequired":true,"text":["春眠不觉晓，","处处闻啼鸟。","夜来风雨声，","花落知多少。"]},{"id":"jing-ye-si","title":"静夜思","author":"李白","dynasty":"唐代","type":"诗","isRequired":true,"text":["床前明月光，","疑是地上霜。","举头望明月，","低头思故乡。"]},{"id":"min-nong","title":"悯农（其二）","author":"李绅","dynasty":"唐代","type":"诗","isRequired":true,"text":["锄禾日当午，","汗滴禾下土。","谁知盘中餐，","粒粒皆辛苦。"]},{"id":"chi-shang","title":"池上","author":"白居易","dynasty":"唐代","type":"诗","isRequired":true,"text":["小娃撑小艇，","偷采白莲回。","不解藏踪迹，","浮萍一道开。"]},{"id":"deng-guan-que-lou","title":"登鹳雀楼","author":"王之涣","dynasty":"唐代","type":"诗","isRequired":true,"text":["白日依山尽，","黄河入海流。","欲穷千里目，","更上一层楼。"]},{"id":"wang-lu-shan-pu-bu","title":"望庐山瀑布","author":"李白","dynasty":"唐代","type":"诗","isRequired":true,"text":["日照香炉生紫烟，","遥看瀑布挂前川。","飞流直下三千尺，","疑是银河落九天。"]},{"id":"yong-liu","title":"咏柳","author":"贺知章","dynasty":"唐代","type":"诗","isRequired":true,"text":["碧玉妆成一树高，","万条垂下绿丝绦。","不知细叶谁裁出，","二月春风似剪刀。"]},{"id":"shan-xing","title":"山行","author":"杜牧","dynasty":"唐代","type":"诗","isRequired":true,"text":["远上寒山石径斜，","白云生处有人家。","停车坐爱枫林晚，","霜叶红于二月花。"]},{"id":"jue-ju-liang-ge-huang-li","title":"绝句","author":"杜甫","dynasty":"唐代","type":"诗","isRequired":true,"text":["两个黄鹂鸣翠柳，","一行白鹭上青天。","窗含西岭千秋雪，","门泊东吴万里船。"]},{"id":"wang-tian-men-shan","title":"望天门山","author":"李白","dynasty":"唐代","type":"诗","isRequired":true,"text":["天门中断楚江开，","碧水东流至此回。","两岸青山相对出，","孤帆一片日边来。"]},{"id":"yin-hu-shang-chu-qing-hou-yu","title":"饮湖上初晴后雨","author":"苏轼","dynasty":"宋代","type":"诗","isRequired":true,"text":["水光潋滟晴方好，","山色空蒙雨亦奇。","欲把西湖比西子，","淡妆浓抹总相宜。"]},{"id":"ti-xi-lin-bi","title":"题西林壁","author":"苏轼","dynasty":"宋代","type":"诗","isRequired":true,"text":["横看成岭侧成峰，","远近高低各不同。","不识庐山真面目，","只缘身在此山中。"]},{"id":"chu-sai","title":"出塞","author":"王昌龄","dynasty":"唐代","type":"诗","isRequired":true,"text":["秦时明月汉时关，","万里长征人未还。","但使龙城飞将在，","不教胡马度阴山。"]},{"id":"shi-er","title":"示儿","author":"陆游","dynasty":"宋代","type":"诗","isRequired":true,"text":["死去元知万事空，","但悲不见九州同。","王师北定中原日，","家祭无忘告乃翁。"]},{"id":"feng-qiao-ye-bo","title":"枫桥夜泊","author":"张继","dynasty":"唐代","type":"诗","isRequired":true,"text":["月落乌啼霜满天，","江枫渔火对愁眠。","姑苏城外寒山寺，","夜半钟声到客船。"]},{"id":"su-jian-de-jiang","title":"宿建德江","author":"孟浩然","dynasty":"唐代","type":"诗","isRequired":true,"text":["移舟泊烟渚，","日暮客愁新。","野旷天低树，","江清月近人。"]},{"id":"chun-ri","title":"春日","author":"朱熹","dynasty":"宋代","type":"诗","isRequired":true,"text":["胜日寻芳泗水滨，","无边光景一时新。","等闲识得东风面，","万紫千红总是春。"]},{"id":"guan-cang-hai","title":"观沧海","author":"曹操","dynasty":"两汉","type":"诗","isRequired":true,"text":["东临碣石，以观沧海。","水何澹澹，山岛竦峙。","树木丛生，百草丰茂。","秋风萧瑟，洪波涌起。","日月之行，若出其中；","星汉灿烂，若出其里。"]},{"id":"tian-jing-sha-qiu-si","title":"天净沙·秋思","author":"马致远","dynasty":"元代","type":"曲","isRequired":true,"text":["枯藤老树昏鸦，","小桥流水人家，","古道西风瘦马。","夕阳西下，","断肠人在天涯。"]},{"id":"ci-bei-gu-shan-xia","title":"次北固山下","author":"王湾","dynasty":"唐代","type":"诗","isRequired":true,"text":["客路青山外，行舟绿水前。","潮平两岸阔，风正一帆悬。","海日生残夜，江春入旧年。","乡书何处达？归雁洛阳边。"]},{"id":"huang-he-lou","title":"黄鹤楼","author":"崔颢","dynasty":"唐代","type":"诗","isRequired":true,"text":["昔人已乘黄鹤去，此地空余黄鹤楼。","黄鹤一去不复返，白云千载空悠悠。","晴川历历汉阳树，芳草萋萋鹦鹉洲。","日暮乡关何处是？烟波江上使人愁。"]},{"id":"shi-zhi-sai-shang","title":"使至塞上","author":"王维","dynasty":"唐代","type":"诗","isRequired":true,"text":["单车欲问边，属国过居延。","征蓬出汉塞，归雁入胡天。","大漠孤烟直，长河落日圆。","萧关逢候骑，都护在燕然。"]},{"id":"xing-lu-nan","title":"行路难","author":"李白","dynasty":"唐代","type":"诗","isRequired":true,"text":["金樽清酒斗十千，玉盘珍羞直万钱。","停杯投箸不能食，拔剑四顾心茫然。","欲渡黄河冰塞川，将登太行雪满山。","闲来垂钓碧溪上，忽复乘舟梦日边。","行路难，行路难，多歧路，今安在？","长风破浪会有时，直挂云帆济沧海。"]},{"id":"shui-diao-ge-tou","title":"水调歌头·明月几时有","author":"苏轼","dynasty":"宋代","type":"词","isRequired":true,"text":["明月几时有？把酒问青天。","不知天上宫阙，今夕是何年。","我欲乘风归去，又恐琼楼玉宇，高处不胜寒。","起舞弄清影，何似在人间。","转朱阁，低绮户，照无眠。","不应有恨，何事长向别时圆？","人有悲欢离合，月有阴晴圆缺，此事古难全。","但愿人长久，千里共婵娟。"]},{"id":"duan-ge-xing","title":"短歌行","author":"曹操","dynasty":"两汉","type":"诗","isRequired":true,"text":["对酒当歌，人生几何！","譬如朝露，去日苦多。","慨当以慷，忧思难忘。","何以解忧？唯有杜康。","青青子衿，悠悠我心。","但为君故，沉吟至今。","呦呦鹿鸣，食野之苹。","我有嘉宾，鼓瑟吹笙。","明明如月，何时可掇？","忧从中来，不可断绝。","越陌度阡，枉用相存。","契阔谈讌，心念旧恩。","月明星稀，乌鹊南飞。","绕树三匝，何枝可依？","山不厌高，海不厌深。","周公吐哺，天下归心。"]},{"id":"deng-gao","title":"登高","author":"杜甫","dynasty":"唐代","type":"诗","isRequired":true,"text":["风急天高猿啸哀，渚清沙白鸟飞回。","无边落木萧萧下，不尽长江滚滚来。","万里悲秋常作客，百年多病独登台。","艰难苦恨繁霜鬓，潦倒新停浊酒杯。"]},{"id":"jin-se","title":"锦瑟","author":"李商隐","dynasty":"唐代","type":"诗","isRequired":true,"text":["锦瑟无端五十弦，一弦一柱思华年。","庄生晓梦迷蝴蝶，望帝春心托杜鹃。","沧海月明珠有泪，蓝田日暖玉生烟。","此情可待成追忆，只是当时已惘然。"]},{"id":"nian-nu-jiao-chi-bi-huai-gu","title":"念奴娇·赤壁怀古","author":"苏轼","dynasty":"宋代","type":"词","isRequired":true,"text":["大江东去，浪淘尽，千古风流人物。","故垒西边，人道是，三国周郎赤壁。","乱石穿空，惊涛拍岸，卷起千堆雪。","江山如画，一时多少豪杰。","遥想公瑾当年，小乔初嫁了，雄姿英发。","羽扇纶巾，谈笑间，樯橹灰飞烟灭。","故国神游，多情应笑我，早生华发。","人生如梦，一尊还酹江月。"]},{"id":"pi-pa-xing","title":"琵琶行（节选）","author":"白居易","dynasty":"唐代","type":"诗","isRequired":true,"text":["浔阳江头夜送客，枫叶荻花秋瑟瑟。","主人下马客在船，举酒欲饮无管弦。","醉不成欢惨将别，别时茫茫江浸月。","忽闻水上琵琶声，主人忘归客不发。","千呼万唤始出来，犹抱琵琶半遮面。","转轴拨弦三两声，未成曲调先有情。","大弦嘈嘈如急雨，小弦切切如私语。","嘈嘈切切错杂弹，大珠小珠落玉盘。"]},{"id":"chi-bi-fu","title":"赤壁赋（节选）","author":"苏轼","dynasty":"宋代","type":"古文","isRequired":true,"text":["壬戌之秋，七月既望，苏子与客泛舟游于赤壁之下。","清风徐来，水波不兴。","举酒属客，诵明月之诗，歌窈窕之章。","少焉，月出于东山之上，徘徊于斗牛之间。","白露横江，水光接天。","纵一苇之所如，凌万顷之茫然。","浩浩乎如冯虚御风，而不知其所止；","飘飘乎如遗世独立，羽化而登仙。"]},{"id":"hua","title":"画","author":"王维","dynasty":"唐代","type":"诗","isRequired":true,"text":["远看山有色，","近听水无声。","春去花还在，","人来鸟不惊。"]},{"id":"gu-lang-yue-xing","title":"古朗月行（节选）","author":"李白","dynasty":"唐代","type":"诗","isRequired":true,"text":["小时不识月，","呼作白玉盘。","又疑瑶台镜，","飞在青云端。"]},{"id":"feng","title":"风","author":"李峤","dynasty":"唐代","type":"诗","isRequired":true,"text":["解落三秋叶，","能开二月花。","过江千尺浪，","入竹万竿斜。"]},{"id":"zeng-wang-lun","title":"赠汪伦","author":"李白","dynasty":"唐代","type":"诗","isRequired":true,"text":["李白乘舟将欲行，","忽闻岸上踏歌声。","桃花潭水深千尺，","不及汪伦送我情。"]},{"id":"xun-yin-zhe-bu-yu","title":"寻隐者不遇","author":"贾岛","dynasty":"唐代","type":"诗","isRequired":true,"text":["松下问童子，","言师采药去。","只在此山中，","云深不知处。"]},{"id":"xiao-chi","title":"小池","author":"杨万里","dynasty":"宋代","type":"诗","isRequired":true,"text":["泉眼无声惜细流，","树阴照水爱晴柔。","小荷才露尖尖角，","早有蜻蜓立上头。"]},{"id":"zeng-liu-jing-wen","title":"赠刘景文","author":"苏轼","dynasty":"宋代","type":"诗","isRequired":true,"text":["荷尽已无擎雨盖，","菊残犹有傲霜枝。","一年好景君须记，","正是橙黄橘绿时。"]},{"id":"cun-ju","title":"村居","author":"高鼎","dynasty":"清代","type":"诗","isRequired":true,"text":["草长莺飞二月天，","拂堤杨柳醉春烟。","儿童散学归来早，","忙趁东风放纸鸢。"]},{"id":"xiao-chu-jing-ci-si-song-lin-zi-fang","title":"晓出净慈寺送林子方","author":"杨万里","dynasty":"宋代","type":"诗","isRequired":true,"text":["毕竟西湖六月中，","风光不与四时同。","接天莲叶无穷碧，","映日荷花别样红。"]},{"id":"fu-de-gu-yuan-cao-song-bie","title":"赋得古原草送别（节选）","author":"白居易","dynasty":"唐代","type":"诗","isRequired":true,"text":["离离原上草，","一岁一枯荣。","野火烧不尽，","春风吹又生。"]},{"id":"ye-shu-suo-jian","title":"夜书所见","author":"叶绍翁","dynasty":"宋代","type":"诗","isRequired":true,"text":["萧萧梧叶送寒声，","江上秋风动客情。","知有儿童挑促织，","夜深篱落一灯明。"]},{"id":"jue-ju-chi-ri","title":"绝句","author":"杜甫","dynasty":"唐代","type":"诗","isRequired":true,"text":["迟日江山丽，","春风花草香。","泥融飞燕子，","沙暖睡鸳鸯。"]},{"id":"yi-jiang-nan","title":"忆江南","author":"白居易","dynasty":"唐代","type":"词","isRequired":true,"text":["江南好，","风景旧曾谙。","日出江花红胜火，","春来江水绿如蓝。","能不忆江南？"]},{"id":"zao-fa-bai-di-cheng","title":"早发白帝城","author":"李白","dynasty":"唐代","type":"诗","isRequired":true,"text":["朝辞白帝彩云间，","千里江陵一日还。","两岸猿声啼不住，","轻舟已过万重山。"]},{"id":"jiu-yue-jiu-ri-yi-shan-dong-xiong-di","title":"九月九日忆山东兄弟","author":"王维","dynasty":"唐代","type":"诗","isRequired":true,"text":["独在异乡为异客，","每逢佳节倍思亲。","遥知兄弟登高处，","遍插茱萸少一人。"]},{"id":"you-shan-xi-cun","title":"游山西村","author":"陆游","dynasty":"宋代","type":"诗","isRequired":true,"text":["莫笑农家腊酒浑，","丰年留客足鸡豚。","山重水复疑无路，","柳暗花明又一村。"]},{"id":"mu-jiang-yin","title":"暮江吟","author":"白居易","dynasty":"唐代","type":"诗","isRequired":true,"text":["一道残阳铺水中，","半江瑟瑟半江红。","可怜九月初三夜，","露似真珠月似弓。"]},{"id":"liang-zhou-ci","title":"凉州词","author":"王翰","dynasty":"唐代","type":"诗","isRequired":true,"text":["葡萄美酒夜光杯，","欲饮琵琶马上催。","醉卧沙场君莫笑，","古来征战几人回？"]},{"id":"xia-ri-jue-ju","title":"夏日绝句","author":"李清照","dynasty":"宋代","type":"诗","isRequired":true,"text":["生当作人杰，","死亦为鬼雄。","至今思项羽，","不肯过江东。"]},{"id":"ti-lin-an-di","title":"题临安邸","author":"林升","dynasty":"宋代","type":"诗","isRequired":true,"text":["山外青山楼外楼，","西湖歌舞几时休？","暖风熏得游人醉，","直把杭州作汴州。"]},{"id":"ji-hai-za-shi","title":"己亥杂诗","author":"龚自珍","dynasty":"清代","type":"诗","isRequired":true,"text":["浩荡离愁白日斜，","吟鞭东指即天涯。","落红不是无情物，","化作春泥更护花。"]},{"id":"shan-ju-qiu-ming","title":"山居秋暝","author":"王维","dynasty":"唐代","type":"诗","isRequired":true,"text":["空山新雨后，","天气晚来秋。","明月松间照，","清泉石上流。","竹喧归浣女，","莲动下渔舟。","随意春芳歇，","王孙自可留。"]},{"id":"si-shi-tian-yuan-za-xing","title":"四时田园杂兴（其二十五）","author":"范成大","dynasty":"宋代","type":"诗","isRequired":true,"text":["梅子金黄杏子肥，","麦花雪白菜花稀。","日长篱落无人过，","惟有蜻蜓蛱蝶飞。"]},{"id":"liu-yue-er-shi-qi-ri-wang-hu-lou-zui-shu","title":"六月二十七日望湖楼醉书","author":"苏轼","dynasty":"宋代","type":"诗","isRequired":true,"text":["黑云翻墨未遮山，","白雨跳珠乱入船。","卷地风来忽吹散，","望湖楼下水如天。"]},{"id":"xi-jiang-yue-ye-xing-huang-sha-dao-zhong","title":"西江月·夜行黄沙道中","author":"辛弃疾","dynasty":"宋代","type":"词","isRequired":true,"text":["明月别枝惊鹊，","清风半夜鸣蝉。","稻花香里说丰年，","听取蛙声一片。","七八个星天外，","两三点雨山前。","旧时茅店社林边，","路转溪桥忽见。"]},{"id":"guo-gu-ren-zhuang","title":"过故人庄","author":"孟浩然","dynasty":"唐代","type":"诗","isRequired":true,"text":["故人具鸡黍，","邀我至田家。","绿树村边合，","青山郭外斜。","开轩面场圃，","把酒话桑麻。","待到重阳日，","还来就菊花。"]},{"id":"hui-xiang-ou-shu","title":"回乡偶书","author":"贺知章","dynasty":"唐代","type":"诗","isRequired":true,"text":["少小离家老大回，","乡音无改鬓毛衰。","儿童相见不相识，","笑问客从何处来。"]},{"id":"qi-lv-chang-zheng","title":"七律·长征","author":"毛泽东","dynasty":"近代","type":"诗","isRequired":true,"text":["红军不怕远征难，","万水千山只等闲。","五岭逶迤腾细浪，","乌蒙磅礴走泥丸。","金沙水拍云崖暖，","大渡桥横铁索寒。","更喜岷山千里雪，","三军过后尽开颜。"]},{"id":"wen-wang-chang-ling-zuo-qian-long-biao-yao-you-ji-ci","title":"闻王昌龄左迁龙标遥有此寄","author":"李白","dynasty":"唐代","type":"诗","isRequired":true,"text":["杨花落尽子规啼，","闻道龙标过五溪。","我寄愁心与明月，","随君直到夜郎西。"]},{"id":"deng-you-zhou-tai-ge","title":"登幽州台歌","author":"陈子昂","dynasty":"唐代","type":"诗","isRequired":true,"text":["前不见古人，","后不见来者。","念天地之悠悠，","独怆然而涕下。"]},{"id":"wang-yue","title":"望岳","author":"杜甫","dynasty":"唐代","type":"诗","isRequired":true,"text":["岱宗夫如何？齐鲁青未了。","造化钟神秀，阴阳割昏晓。","荡胸生曾云，决眦入归鸟。","会当凌绝顶，一览众山小。"]},{"id":"deng-fei-lai-feng","title":"登飞来峰","author":"王安石","dynasty":"宋代","type":"诗","isRequired":true,"text":["飞来山上千寻塔，","闻说鸡鸣见日升。","不畏浮云遮望眼，","自缘身在最高层。"]},{"id":"mu-lan-shi","title":"木兰诗（节选）","author":"佚名","dynasty":"南北朝","type":"诗","isRequired":true,"text":["万里赴戎机，","关山度若飞。","朔气传金柝，","寒光照铁衣。","将军百战死，","壮士十年归。"]},{"id":"qian-tang-hu-chun-xing","title":"钱塘湖春行","author":"白居易","dynasty":"唐代","type":"诗","isRequired":true,"text":["孤山寺北贾亭西，","水面初平云脚低。","几处早莺争暖树，","谁家新燕啄春泥。","乱花渐欲迷人眼，","浅草才能没马蹄。","最爱湖东行不足，","绿杨阴里白沙堤。"]},{"id":"yin-jiu","title":"饮酒（其五）","author":"陶渊明","dynasty":"魏晋","type":"诗","isRequired":true,"text":["结庐在人境，而无车马喧。","问君何能尔？心远地自偏。","采菊东篱下，悠然见南山。","山气日夕佳，飞鸟相与还。","此中有真意，欲辨已忘言。"]},{"id":"chun-wang","title":"春望","author":"杜甫","dynasty":"唐代","type":"诗","isRequired":true,"text":["国破山河在，城春草木深。","感时花溅泪，恨别鸟惊心。","烽火连三月，家书抵万金。","白头搔更短，浑欲不胜簪。"]},{"id":"yan-men-tai-shou-xing","title":"雁门太守行","author":"李贺","dynasty":"唐代","type":"诗","isRequired":true,"text":["黑云压城城欲摧，","甲光向日金鳞开。","角声满天秋色里，","塞上燕脂凝夜紫。","半卷红旗临易水，","霜重鼓寒声不起。","报君黄金台上意，","提携玉龙为君死。"]},{"id":"chi-bi-du-mu","title":"赤壁","author":"杜牧","dynasty":"唐代","type":"诗","isRequired":true,"text":["折戟沉沙铁未销，","自将磨洗认前朝。","东风不与周郎便，","铜雀春深锁二乔。"]},{"id":"chou-le-tian-yang-zhou-chu-feng-xi-shang-jian-zeng","title":"酬乐天扬州初逢席上见赠","author":"刘禹锡","dynasty":"唐代","type":"诗","isRequired":true,"text":["巴山楚水凄凉地，","二十三年弃置身。","怀旧空吟闻笛赋，","到乡翻似烂柯人。","沉舟侧畔千帆过，","病树前头万木春。","今日听君歌一曲，","暂凭杯酒长精神。"]},{"id":"yue-ye-yi-she-di","title":"月夜忆舍弟","author":"杜甫","dynasty":"唐代","type":"诗","isRequired":true,"text":["戍鼓断人行，边秋一雁声。","露从今夜白，月是故乡明。","有弟皆分散，无家问死生。","寄书长不达，况乃未休兵。"]},{"id":"yue-yang-lou-ji","title":"岳阳楼记（节选）","author":"范仲淹","dynasty":"宋代","type":"古文","isRequired":true,"text":["不以物喜，不以己悲。","居庙堂之高则忧其民，","处江湖之远则忧其君。","是进亦忧，退亦忧。","然则何时而乐耶？","其必曰：先天下之忧而忧，","后天下之乐而乐乎！"]},{"id":"zui-weng-ting-ji","title":"醉翁亭记（节选）","author":"欧阳修","dynasty":"宋代","type":"古文","isRequired":true,"text":["醉翁之意不在酒，","在乎山水之间也。","山水之乐，","得之心而寓之酒也。"]},{"id":"gui-yuan-tian-ju","title":"归园田居（其一）","author":"陶渊明","dynasty":"魏晋","type":"诗","isRequired":true,"text":["少无适俗韵，性本爱丘山。","误落尘网中，一去三十年。","羁鸟恋旧林，池鱼思故渊。","开荒南野际，守拙归园田。","方宅十余亩，草屋八九间。","榆柳荫后檐，桃李罗堂前。","暧暧远人村，依依墟里烟。","狗吠深巷中，鸡鸣桑树颠。","户庭无尘杂，虚室有余闲。","久在樊笼里，复得返自然。"]},{"id":"meng-you-tian-lao-yin-liu-bie","title":"梦游天姥吟留别（节选）","author":"李白","dynasty":"唐代","type":"诗","isRequired":true,"text":["海客谈瀛洲，烟涛微茫信难求。","越人语天姥，云霞明灭或可睹。","天姥连天向天横，势拔五岳掩赤城。","天台四万八千丈，对此欲倒东南倾。","世间行乐亦如此，古来万事东流水。","别君去兮何时还？","且放白鹿青崖间，须行即骑访名山。","安能摧眉折腰事权贵，使我不得开心颜！"]},{"id":"shu-dao-nan","title":"蜀道难（节选）","author":"李白","dynasty":"唐代","type":"诗","isRequired":true,"text":["噫吁嚱，危乎高哉！","蜀道之难，难于上青天！","蚕丛及鱼凫，开国何茫然！","尔来四万八千岁，不与秦塞通人烟。","飞湍瀑流争喧豗，砯崖转石万壑雷。","蜀道之难，难于上青天，使人听此凋朱颜！"]},{"id":"yu-mei-ren","title":"虞美人","author":"李煜","dynasty":"五代","type":"词","isRequired":true,"text":["春花秋月何时了？往事知多少。","小楼昨夜又东风，","故国不堪回首月明中。","雕栏玉砌应犹在，只是朱颜改。","问君能有几多愁？","恰似一江春水向东流。"]},{"id":"quan-xue","title":"劝学（节选）","author":"荀子","dynasty":"先秦","type":"古文","isRequired":true,"text":["青，取之于蓝，而青于蓝；","冰，水为之，而寒于水。","学不可以已。","故不积跬步，无以至千里；","不积小流，无以成江海。"]},{"id":"shi-shuo","title":"师说（节选）","author":"韩愈","dynasty":"唐代","type":"古文","isRequired":true,"text":["师者，所以传道受业解惑也。","人非生而知之者，孰能无惑？","惑而不从师，其为惑也，终不解矣。","吾师道也，夫庸知其年之先后生于吾乎？","是故无贵无贱，无长无少，","道之所存，师之所存也。"]},{"id":"guan-ju","title":"关雎","author":"佚名","dynasty":"先秦","type":"诗","isRequired":true,"text":["关关雎鸠，在河之洲。","窈窕淑女，君子好逑。","参差荇菜，左右流之。","窈窕淑女，寤寐求之。","求之不得，寤寐思服。","悠哉悠哉，辗转反侧。","参差荇菜，左右采之。","窈窕淑女，琴瑟友之。","参差荇菜，左右芼之。","窈窕淑女，钟鼓乐之。"]},{"id":"jian-jia","title":"蒹葭","author":"佚名","dynasty":"先秦","type":"诗","isRequired":true,"text":["蒹葭苍苍，白露为霜。","所谓伊人，在水一方。","溯洄从之，道阻且长。","溯游从之，宛在水中央。","蒹葭萋萋，白露未晞。","所谓伊人，在水之湄。","溯洄从之，道阻且跻。","溯游从之，宛在水中坻。"]},{"id":"jiang-nan","title":"江南","author":"佚名","dynasty":"两汉","type":"诗","isRequired":true,"text":["江南可采莲，","莲叶何田田。","鱼戏莲叶间。","鱼戏莲叶东，","鱼戏莲叶西，","鱼戏莲叶南，","鱼戏莲叶北。"]},{"id":"hua-ji","title":"画鸡","author":"唐寅","dynasty":"明代","type":"诗","isRequired":true,"text":["头上红冠不用裁，","满身雪白走将来。","平生不敢轻言语，","一叫千门万户开。"]},{"id":"ye-su-shan-si","title":"夜宿山寺","author":"李白","dynasty":"唐代","type":"诗","isRequired":true,"text":["危楼高百尺，","手可摘星辰。","不敢高声语，","恐惊天上人。"]},{"id":"chi-le-ge","title":"敕勒歌","author":"佚名","dynasty":"南北朝","type":"诗","isRequired":true,"text":["敕勒川，阴山下。","天似穹庐，笼盖四野。","天苍苍，野茫茫，","风吹草低见牛羊。"]},{"id":"xiao-er-chui-diao","title":"小儿垂钓","author":"胡令能","dynasty":"唐代","type":"诗","isRequired":true,"text":["蓬头稚子学垂纶，","侧坐莓苔草映身。","路人借问遥招手，","怕得鱼惊不应人。"]},{"id":"min-nong-yi","title":"悯农（其一）","author":"李绅","dynasty":"唐代","type":"诗","isRequired":true,"text":["春种一粒粟，","秋收万颗子。","四海无闲田，","农夫犹饿死。"]},{"id":"mei-hua","title":"梅花","author":"王安石","dynasty":"宋代","type":"诗","isRequired":true,"text":["墙角数枝梅，","凌寒独自开。","遥知不是雪，","为有暗香来。"]},{"id":"yuan-ri","title":"元日","author":"王安石","dynasty":"宋代","type":"诗","isRequired":true,"text":["爆竹声中一岁除，","春风送暖入屠苏。","千门万户曈曈日，","总把新桃换旧符。"]},{"id":"qing-ming","title":"清明","author":"杜牧","dynasty":"唐代","type":"诗","isRequired":true,"text":["清明时节雨纷纷，","路上行人欲断魂。","借问酒家何处有，","牧童遥指杏花村。"]},{"id":"hui-chong-chun-jiang-wan-jing","title":"惠崇春江晚景","author":"苏轼","dynasty":"宋代","type":"诗","isRequired":true,"text":["竹外桃花三两枝，","春江水暖鸭先知。","蒌蒿满地芦芽短，","正是河豚欲上时。"]},{"id":"san-qu-dao-zhong","title":"三衢道中","author":"曾几","dynasty":"宋代","type":"诗","isRequired":true,"text":["梅子黄时日日晴，","小溪泛尽却山行。","绿阴不减来时路，","添得黄鹂四五声。"]},{"id":"chu-zhou-xi-jian","title":"滁州西涧","author":"韦应物","dynasty":"唐代","type":"诗","isRequired":true,"text":["独怜幽草涧边生，","上有黄鹂深树鸣。","春潮带雨晚来急，","野渡无人舟自横。"]},{"id":"da-lin-si-tao-hua","title":"大林寺桃花","author":"白居易","dynasty":"唐代","type":"诗","isRequired":true,"text":["人间四月芳菲尽，","山寺桃花始盛开。","长恨春归无觅处，","不知转入此中来。"]},{"id":"fu-rong-lou-song-xin-jian","title":"芙蓉楼送辛渐","author":"王昌龄","dynasty":"唐代","type":"诗","isRequired":true,"text":["寒雨连江夜入吴，","平明送客楚山孤。","洛阳亲友如相问，","一片冰心在玉壶。"]},{"id":"sai-xia-qu","title":"塞下曲","author":"卢纶","dynasty":"唐代","type":"诗","isRequired":true,"text":["月黑雁飞高，","单于夜遁逃。","欲将轻骑逐，","大雪满弓刀。"]},{"id":"mo-mei","title":"墨梅","author":"王冕","dynasty":"元代","type":"诗","isRequired":true,"text":["吾家洗砚池头树，","朵朵花开淡墨痕。","不要人夸好颜色，","只留清气满乾坤。"]},{"id":"si-shi-tian-yuan-za-xing-san-shi-yi","title":"四时田园杂兴（其三十一）","author":"范成大","dynasty":"宋代","type":"诗","isRequired":true,"text":["昼出耘田夜绩麻，","村庄儿女各当家。","童孙未解供耕织，","也傍桑阴学种瓜。"]},{"id":"su-xin-shi-xu-gong-dian","title":"宿新市徐公店","author":"杨万里","dynasty":"宋代","type":"诗","isRequired":true,"text":["篱落疏疏一径深，","树头新绿未成阴。","儿童急走追黄蝶，","飞入菜花无处寻。"]},{"id":"qing-ping-yue-cun-ju","title":"清平乐·村居","author":"辛弃疾","dynasty":"宋代","type":"词","isRequired":true,"text":["茅檐低小，溪上青青草。","醉里吴音相媚好，白发谁家翁媪？","大儿锄豆溪东，中儿正织鸡笼。","最喜小儿亡赖，溪头卧剥莲蓬。"]},{"id":"chang-xiang-si","title":"长相思","author":"纳兰性德","dynasty":"清代","type":"词","isRequired":true,"text":["山一程，水一程，","身向榆关那畔行，夜深千帐灯。","风一更，雪一更，","聒碎乡心梦不成，故园无此声。"]},{"id":"yu-ge-zi","title":"渔歌子","author":"张志和","dynasty":"唐代","type":"词","isRequired":true,"text":["西塞山前白鹭飞，","桃花流水鳜鱼肥。","青箬笠，绿蓑衣，","斜风细雨不须归。"]},{"id":"niao-ming-jian","title":"鸟鸣涧","author":"王维","dynasty":"唐代","type":"诗","isRequired":true,"text":["人闲桂花落，","夜静春山空。","月出惊山鸟，","时鸣春涧中。"]},{"id":"liang-zhou-ci-huang-he","title":"凉州词（黄河远上）","author":"王之涣","dynasty":"唐代","type":"诗","isRequired":true,"text":["黄河远上白云间，","一片孤城万仞山。","羌笛何须怨杨柳，","春风不度玉门关。"]},{"id":"song-yuan-er-shi-an-xi","title":"送元二使安西","author":"王维","dynasty":"唐代","type":"诗","isRequired":true,"text":["渭城朝雨浥轻尘，","客舍青青柳色新。","劝君更尽一杯酒，","西出阳关无故人。"]},{"id":"qiu-ye-jiang-xiao","title":"秋夜将晓出篱门迎凉有感","author":"陆游","dynasty":"宋代","type":"诗","isRequired":true,"text":["三万里河东入海，","五千仞岳上摩天。","遗民泪尽胡尘里，","南望王师又一年。"]},{"id":"shi-hui-yin","title":"石灰吟","author":"于谦","dynasty":"明代","type":"诗","isRequired":true,"text":["千锤万凿出深山，","烈火焚烧若等闲。","粉骨碎身浑不怕，","要留清白在人间。"]},{"id":"zhu-shi","title":"竹石","author":"郑燮","dynasty":"清代","type":"诗","isRequired":true,"text":["咬定青山不放松，","立根原在破岩中。","千磨万击还坚劲，","任尔东西南北风。"]},{"id":"wen-guan-jun-shou-he-nan-he-bei","title":"闻官军收河南河北","author":"杜甫","dynasty":"唐代","type":"诗","isRequired":true,"text":["剑外忽传收蓟北，","初闻涕泪满衣裳。","却看妻子愁何在，","漫卷诗书喜欲狂。","白日放歌须纵酒，","青春作伴好还乡。","即从巴峡穿巫峡，","便下襄阳向洛阳。"]},{"id":"zao-chen-cheng-shui-bu","title":"早春呈水部张十八员外","author":"韩愈","dynasty":"唐代","type":"诗","isRequired":true,"text":["天街小雨润如酥，","草色遥看近却无。","最是一年春好处，","绝胜烟柳满皇都。"]},{"id":"han-shi","title":"寒食","author":"韩翃","dynasty":"唐代","type":"诗","isRequired":true,"text":["春城无处不飞花，","寒食东风御柳斜。","日暮汉宫传蜡烛，","轻烟散入五侯家。"]},{"id":"jiang-shang-yu-zhe","title":"江上渔者","author":"范仲淹","dynasty":"宋代","type":"诗","isRequired":true,"text":["江上往来人，","但爱鲈鱼美。","君看一叶舟，","出没风波里。"]},{"id":"bo-chuan-gua-zhou","title":"泊船瓜洲","author":"王安石","dynasty":"宋代","type":"诗","isRequired":true,"text":["京口瓜洲一水间，","钟山只隔数重山。","春风又绿江南岸，","明月何时照我还。"]},{"id":"chang-ge-xing","title":"长歌行","author":"佚名","dynasty":"两汉","type":"诗","isRequired":true,"text":["青青园中葵，朝露待日晞。","阳春布德泽，万物生光辉。","常恐秋节至，焜黄华叶衰。","百川东到海，何时复西归？","少壮不努力，老大徒伤悲。"]},{"id":"lu-chai","title":"鹿柴","author":"王维","dynasty":"唐代","type":"诗","isRequired":true,"text":["空山不见人，","但闻人语响。","返景入深林，","复照青苔上。"]},{"id":"du-zuo-jing-ting-shan","title":"独坐敬亭山","author":"李白","dynasty":"唐代","type":"诗","isRequired":true,"text":["众鸟高飞尽，","孤云独去闲。","相看两不厌，","只有敬亭山。"]},{"id":"huang-he-lou-song-meng-hao-ran","title":"黄鹤楼送孟浩然之广陵","author":"李白","dynasty":"唐代","type":"诗","isRequired":true,"text":["故人西辞黄鹤楼，","烟花三月下扬州。","孤帆远影碧空尽，","唯见长江天际流。"]},{"id":"bie-dong-da","title":"别董大","author":"高适","dynasty":"唐代","type":"诗","isRequired":true,"text":["千里黄云白日曛，","北风吹雁雪纷纷。","莫愁前路无知己，","天下谁人不识君。"]},{"id":"chun-ye-xi-yu","title":"春夜喜雨","author":"杜甫","dynasty":"唐代","type":"诗","isRequired":true,"text":["好雨知时节，当春乃发生。","随风潜入夜，润物细无声。","野径云俱黑，江船火独明。","晓看红湿处，花重锦官城。"]},{"id":"jiang-pan-du-bu-xun-hua","title":"江畔独步寻花","author":"杜甫","dynasty":"唐代","type":"诗","isRequired":true,"text":["黄四娘家花满蹊，","千朵万朵压枝低。","留连戏蝶时时舞，","自在娇莺恰恰啼。"]},{"id":"you-zi-yin","title":"游子吟","author":"孟郊","dynasty":"唐代","type":"诗","isRequired":true,"text":["慈母手中线，","游子身上衣。","临行密密缝，","意恐迟迟归。","谁言寸草心，","报得三春晖。"]},{"id":"wang-dong-ting","title":"望洞庭","author":"刘禹锡","dynasty":"唐代","type":"诗","isRequired":true,"text":["湖光秋月两相和，","潭面无风镜未磨。","遥望洞庭山水翠，","白银盘里一青螺。"]},{"id":"lang-tao-sha","title":"浪淘沙（九曲黄河）","author":"刘禹锡","dynasty":"唐代","type":"诗","isRequired":true,"text":["九曲黄河万里沙，","浪淘风簸自天涯。","如今直上银河去，","同到牵牛织女家。"]},{"id":"jiang-xue","title":"江雪","author":"柳宗元","dynasty":"唐代","type":"诗","isRequired":true,"text":["千山鸟飞绝，","万径人踪灭。","孤舟蓑笠翁，","独钓寒江雪。"]},{"id":"jiang-nan-chun","title":"江南春","author":"杜牧","dynasty":"唐代","type":"诗","isRequired":true,"text":["千里莺啼绿映红，","水村山郭酒旗风。","南朝四百八十寺，","多少楼台烟雨中。"]},{"id":"shu-hu-yin-xian-sheng-bi","title":"书湖阴先生壁","author":"王安石","dynasty":"宋代","type":"诗","isRequired":true,"text":["茅檐长扫净无苔，","花木成畦手自栽。","一水护田将绿绕，","两山排闼送青来。"]},{"id":"guan-shu-you-gan","title":"观书有感","author":"朱熹","dynasty":"宋代","type":"诗","isRequired":true,"text":["半亩方塘一鉴开，","天光云影共徘徊。","问渠那得清如许？","为有源头活水来。"]},{"id":"you-yuan-bu-zhi","title":"游园不值","author":"叶绍翁","dynasty":"宋代","type":"诗","isRequired":true,"text":["应怜屐齿印苍苔，","小扣柴扉久不开。","春色满园关不住，","一枝红杏出墙来。"]},{"id":"xiang-cun-si-yue","title":"乡村四月","author":"翁卷","dynasty":"宋代","type":"诗","isRequired":true,"text":["绿遍山原白满川，","子规声里雨如烟。","乡村四月闲人少，","才了蚕桑又插田。"]},{"id":"suo-jian","title":"所见","author":"袁枚","dynasty":"清代","type":"诗","isRequired":true,"text":["牧童骑黄牛，","歌声振林樾。","意欲捕鸣蝉，","忽然闭口立。"]},{"id":"e-mei-shan-yue-ge","title":"峨眉山月歌","author":"李白","dynasty":"唐代","type":"诗","isRequired":true,"text":["峨眉山月半轮秋，","影入平羌江水流。","夜发清溪向三峡，","思君不见下渝州。"]},{"id":"jiang-nan-feng-li-gui-nian","title":"江南逢李龟年","author":"杜甫","dynasty":"唐代","type":"诗","isRequired":true,"text":["岐王宅里寻常见，","崔九堂前几度闻。","正是江南好风景，","落花时节又逢君。"]},{"id":"qiu-ci-yi","title":"秋词（其一）","author":"刘禹锡","dynasty":"唐代","type":"诗","isRequired":true,"text":["自古逢秋悲寂寥，","我言秋日胜春朝。","晴空一鹤排云上，","便引诗情到碧霄。"]},{"id":"ye-yu-ji-bei","title":"夜雨寄北","author":"李商隐","dynasty":"唐代","type":"诗","isRequired":true,"text":["君问归期未有期，","巴山夜雨涨秋池。","何当共剪西窗烛，","却话巴山夜雨时。"]},{"id":"shi-yi-yue-si-ri","title":"十一月四日风雨大作（其二）","author":"陆游","dynasty":"宋代","type":"诗","isRequired":true,"text":["僵卧孤村不自哀，","尚思为国戍轮台。","夜阑卧听风吹雨，","铁马冰河入梦来。"]},{"id":"zhu-li-guan","title":"竹里馆","author":"王维","dynasty":"唐代","type":"诗","isRequired":true,"text":["独坐幽篁里，","弹琴复长啸。","深林人不知，","明月来相照。"]},{"id":"chun-ye-luo-cheng-wen-di","title":"春夜洛城闻笛","author":"李白","dynasty":"唐代","type":"诗","isRequired":true,"text":["谁家玉笛暗飞声，","散入春风满洛城。","此夜曲中闻折柳，","何人不起故园情。"]},{"id":"feng-ru-jing-shi","title":"逢入京使","author":"岑参","dynasty":"唐代","type":"诗","isRequired":true,"text":["故园东望路漫漫，","双袖龙钟泪不干。","马上相逢无纸笔，","凭君传语报平安。"]},{"id":"bo-qin-huai","title":"泊秦淮","author":"杜牧","dynasty":"唐代","type":"诗","isRequired":true,"text":["烟笼寒水月笼沙，","夜泊秦淮近酒家。","商女不知亡国恨，","隔江犹唱后庭花。"]},{"id":"wan-chun","title":"晚春","author":"韩愈","dynasty":"唐代","type":"诗","isRequired":true,"text":["草树知春不久归，","百般红紫斗芳菲。","杨花榆荚无才思，","惟解漫天作雪飞。"]},{"id":"ye-wang","title":"野望","author":"王绩","dynasty":"唐代","type":"诗","isRequired":true,"text":["东皋薄暮望，","徙倚欲何依。","树树皆秋色，","山山唯落晖。","牧人驱犊返，","猎马带禽归。","相顾无相识，","长歌怀采薇。"]},{"id":"du-jing-men-song-bie","title":"渡荆门送别","author":"李白","dynasty":"唐代","type":"诗","isRequired":true,"text":["渡远荆门外，","来从楚国游。","山随平野尽，","江入大荒流。","月下飞天镜，","云生结海楼。","仍怜故乡水，","万里送行舟。"]},{"id":"yu-jia-ao","title":"渔家傲（天接云涛连晓雾）","author":"李清照","dynasty":"宋代","type":"词","isRequired":true,"text":["天接云涛连晓雾，星河欲转千帆舞。","仿佛梦魂归帝所，闻天语，殷勤问我归何处。","我报路长嗟日暮，学诗谩有惊人句。","九万里风鹏正举。风休住，蓬舟吹取三山去。"]},{"id":"song-du-shao-fu","title":"送杜少府之任蜀州","author":"王勃","dynasty":"唐代","type":"诗","isRequired":true,"text":["城阙辅三秦，","风烟望五津。","与君离别意，","同是宦游人。","海内存知己，","天涯若比邻。","无为在歧路，","儿女共沾巾。"]},{"id":"mao-wu-wei-qiu-feng","title":"茅屋为秋风所破歌（节选）","author":"杜甫","dynasty":"唐代","type":"诗","isRequired":true,"text":["安得广厦千万间，","大庇天下寒士俱欢颜！","风雨不动安如山。","呜呼！何时眼前突兀见此屋，","吾庐独破受冻死亦足！"]},{"id":"mai-tan-weng","title":"卖炭翁（节选）","author":"白居易","dynasty":"唐代","type":"诗","isRequired":true,"text":["卖炭翁，伐薪烧炭南山中。","满面尘灰烟火色，","两鬓苍苍十指黑。","卖炭得钱何所营？","身上衣裳口中食。","可怜身上衣正单，","心忧炭贱愿天寒。"]},{"id":"ti-po-shan-si","title":"题破山寺后禅院","author":"常建","dynasty":"唐代","type":"诗","isRequired":true,"text":["清晨入古寺，","初日照高林。","曲径通幽处，","禅房花木深。","山光悦鸟性，","潭影空人心。","万籁此都寂，","但余钟磬音。"]},{"id":"song-you-ren","title":"送友人","author":"李白","dynasty":"唐代","type":"诗","isRequired":true,"text":["青山横北郭，","白水绕东城。","此地一为别，","孤蓬万里征。","浮云游子意，","落日故人情。","挥手自兹去，","萧萧班马鸣。"]},{"id":"wu-ti","title":"无题","author":"李商隐","dynasty":"唐代","type":"诗","isRequired":true,"text":["相见时难别亦难，","东风无力百花残。","春蚕到死丝方尽，","蜡炬成灰泪始干。","晓镜但愁云鬓改，","夜吟应觉月光寒。","蓬山此去无多路，","青鸟殷勤为探看。"]},{"id":"bai-xue-ge-song-pan-guan","title":"白雪歌送武判官归京（节选）","author":"岑参","dynasty":"唐代","type":"诗","isRequired":true,"text":["北风卷地白草折，","胡天八月即飞雪。","忽如一夜春风来，","千树万树梨花开。","瀚海阑干百丈冰，","愁云惨淡万里凝。","山回路转不见君，","雪上空留马行处。"]},{"id":"nan-xiang-zi","title":"南乡子·登京口北固亭有怀","author":"辛弃疾","dynasty":"宋代","type":"词","isRequired":true,"text":["何处望神州？满眼风光北固楼。","千古兴亡多少事？悠悠。不尽长江滚滚流。","年少万兜鍪，坐断东南战未休。","天下英雄谁敌手？曹刘。生子当如孙仲谋。"]},{"id":"guo-ling-ding-yang","title":"过零丁洋","author":"文天祥","dynasty":"宋代","type":"诗","isRequired":true,"text":["辛苦遭逢起一经，","干戈寥落四周星。","山河破碎风飘絮，","身世浮沉雨打萍。","惶恐滩头说惶恐，","零丁洋里叹零丁。","人生自古谁无死？","留取丹心照汗青。"]},{"id":"po-zhen-zi","title":"破阵子·为陈同甫赋壮词以寄之","author":"辛弃疾","dynasty":"宋代","type":"词","isRequired":true,"text":["醉里挑灯看剑，梦回吹角连营。","八百里分麾下炙，五十弦翻塞外声，沙场秋点兵。","马作的卢飞快，弓如霹雳弦惊。","了却君王天下事，赢得生前身后名。可怜白发生！"]},{"id":"jiang-cheng-zi-mi-zhou","title":"江城子·密州出猎","author":"苏轼","dynasty":"宋代","type":"词","isRequired":true,"text":["老夫聊发少年狂，左牵黄，右擎苍，","锦帽貂裘，千骑卷平冈。","为报倾城随太守，亲射虎，看孙郎。","酒酣胸胆尚开张。鬓微霜，又何妨！","持节云中，何日遣冯唐？","会挽雕弓如满月，西北望，射天狼。"]},{"id":"ding-feng-bo","title":"定风波","author":"苏轼","dynasty":"宋代","type":"词","isRequired":true,"text":["莫听穿林打叶声，何妨吟啸且徐行。","竹杖芒鞋轻胜马，谁怕？一蓑烟雨任平生。","料峭春风吹酒醒，微冷，山头斜照却相迎。","回首向来萧瑟处，归去，也无风雨也无晴。"]},{"id":"man-jiang-hong","title":"满江红（小住京华）","author":"秋瑾","dynasty":"近代","type":"词","isRequired":true,"text":["小住京华，早又是中秋佳节。","为篱下黄花开遍，秋容如拭。","四面歌残终破楚，八年风味徒思浙。","苦将侬强派作蛾眉，殊未屑！","身不得，男儿列。心却比，男儿烈。","算平生肝胆，因人常热。","俗子胸襟谁识我？英雄末路当磨折。","莽红尘何处觅知音？青衫湿！"]},{"id":"jing-nv","title":"静女","author":"佚名","dynasty":"先秦","type":"诗","isRequired":true,"text":["静女其姝，俟我于城隅。","爱而不见，搔首踟蹰。","静女其娈，贻我彤管。","彤管有炜，说怿女美。","自牧归荑，洵美且异。","匪女之为美，美人之贻。"]},{"id":"she-jiang-cai-fu-rong","title":"涉江采芙蓉","author":"佚名","dynasty":"两汉","type":"诗","isRequired":true,"text":["涉江采芙蓉，","兰泽多芳草。","采之欲遗谁？","所思在远道。","还顾望旧乡，","长路漫浩浩。","同心而离居，","忧伤以终老。"]},{"id":"li-sao","title":"离骚（节选）","author":"屈原","dynasty":"先秦","type":"诗","isRequired":true,"text":["长太息以掩涕兮，哀民生之多艰。","余虽好修姱以鞿羁兮，謇朝谇而夕替。","亦余心之所善兮，虽九死其犹未悔。","路曼曼其修远兮，吾将上下而求索。"]},{"id":"yong-yu-le","title":"永遇乐·京口北固亭怀古","author":"辛弃疾","dynasty":"宋代","type":"词","isRequired":true,"text":["千古江山，英雄无觅孙仲谋处。","舞榭歌台，风流总被雨打风吹去。","斜阳草树，寻常巷陌，人道寄奴曾住。","想当年，金戈铁马，气吞万里如虎。","元嘉草草，封狼居胥，赢得仓皇北顾。","四十三年，望中犹记，烽火扬州路。","可堪回首，佛狸祠下，一片神鸦社鼓。","凭谁问，廉颇老矣，尚能饭否？"]},{"id":"gui-qu-lai-xi-ci","title":"归去来兮辞（节选）","author":"陶渊明","dynasty":"魏晋","type":"古文","isRequired":true,"text":["归去来兮，田园将芜胡不归？","既自以心为形役，奚惆怅而独悲？","悟已往之不谏，知来者之可追。","实迷途其未远，觉今是而昨非。","舟遥遥以轻飏，风飘飘而吹衣。","问征夫以前路，恨晨光之熹微。"]},{"id":"sheng-sheng-man","title":"声声慢","author":"李清照","dynasty":"宋代","type":"词","isRequired":true,"text":["寻寻觅觅，冷冷清清，凄凄惨惨戚戚。","乍暖还寒时候，最难将息。","三杯两盏淡酒，怎敌他、晚来风急！","雁过也，正伤心，却是旧时相识。","满地黄花堆积，憔悴损，如今有谁堪摘？","守着窗儿，独自怎生得黑！","梧桐更兼细雨，到黄昏、点点滴滴。","这次第，怎一个愁字了得！"]},{"id":"que-qiao-xian","title":"鹊桥仙","author":"秦观","dynasty":"宋代","type":"词","isRequired":true,"text":["纤云弄巧，飞星传恨，银汉迢迢暗度。","金风玉露一相逢，便胜却人间无数。","柔情似水，佳期如梦，忍顾鹊桥归路！","两情若是久长时，又岂在朝朝暮暮。"]},{"id":"lin-an-chun-yu-chu-ji","title":"临安春雨初霁","author":"陆游","dynasty":"宋代","type":"诗","isRequired":true,"text":["世味年来薄似纱，","谁令骑马客京华。","小楼一夜听春雨，","深巷明朝卖杏花。","矮纸斜行闲作草，","晴窗细乳戏分茶。","素衣莫起风尘叹，","犹及清明可到家。"]},{"id":"shu-xiang","title":"蜀相","author":"杜甫","dynasty":"唐代","type":"诗","isRequired":true,"text":["丞相祠堂何处寻？","锦官城外柏森森。","映阶碧草自春色，","隔叶黄鹂空好音。","三顾频烦天下计，","两朝开济老臣心。","出师未捷身先死，","长使英雄泪满襟。"]},{"id":"wang-hai-chao","title":"望海潮（东南形胜）","author":"柳永","dynasty":"宋代","type":"词","isRequired":true,"text":["东南形胜，三吴都会，钱塘自古繁华。","烟柳画桥，风帘翠幕，参差十万人家。","云树绕堤沙，怒涛卷霜雪，天堑无涯。","市列珠玑，户盈罗绮，竞豪奢。","重湖叠巘清嘉，有三秋桂子，十里荷花。","羌管弄晴，菱歌泛夜，嬉嬉钓叟莲娃。","千骑拥高牙，乘醉听箫鼓，吟赏烟霞。","异日图将好景，归去凤池夸。"]},{"id":"yang-zhou-man","title":"扬州慢（淮左名都）","author":"姜夔","dynasty":"宋代","type":"词","isRequired":true,"text":["淮左名都，竹西佳处，解鞍少驻初程。","过春风十里，尽荠麦青青。","自胡马窥江去后，废池乔木，犹厌言兵。","渐黄昏，清角吹寒，都在空城。","杜郎俊赏，算而今重到须惊。","纵豆蔻词工，青楼梦好，难赋深情。","二十四桥仍在，波心荡，冷月无声。","念桥边红药，年年知为谁生？"]},{"id":"ju-hua-yin","title":"醉花阴","author":"李清照","dynasty":"宋代","type":"词","isRequired":true,"text":["薄雾浓云愁永昼，","瑞脑消金兽。","佳节又重阳，","玉枕纱厨，半夜凉初透。","东篱把酒黄昏后，","有暗香盈袖。","莫道不消魂，","帘卷西风，人比黄花瘦。"]},{"id":"yu-lin-lin","title":"雨霖铃（寒蝉凄切）","author":"柳永","dynasty":"宋代","type":"词","isRequired":true,"text":["寒蝉凄切，对长亭晚，骤雨初歇。","都门帐饮无绪，留恋处，兰舟催发。","执手相看泪眼，竟无语凝噎。","念去去，千里烟波，暮霭沉沉楚天阔。","多情自古伤离别，更那堪，冷落清秋节！","今宵酒醒何处？杨柳岸，晓风残月。","此去经年，应是良辰好景虚设。","便纵有千种风情，更与何人说？"]},{"id":"jiang-jin-jiu","title":"将进酒","author":"李白","dynasty":"唐代","type":"诗","isRequired":true,"text":["君不见黄河之水天上来，","奔流到海不复回。","君不见高堂明镜悲白发，","朝如青丝暮成雪。","人生得意须尽欢，","莫使金樽空对月。","天生我材必有用，","千金散尽还复来。"]},{"id":"shu-fen","title":"书愤","author":"陆游","dynasty":"宋代","type":"诗","isRequired":true,"text":["早岁那知世事艰，","中原北望气如山。","楼船夜雪瓜洲渡，","铁马秋风大散关。","塞上长城空自许，","镜中衰鬓已先斑。","出师一表真名世，","千载谁堪伯仲间。"]},{"id":"qing-yu-an","title":"青玉案·元夕","author":"辛弃疾","dynasty":"宋代","type":"词","isRequired":true,"text":["东风夜放花千树，更吹落，星如雨。","宝马雕车香满路。","凤箫声动，玉壶光转，一夜鱼龙舞。","蛾儿雪柳黄金缕，笑语盈盈暗香去。","众里寻他千百度，蓦然回首，那人却在，灯火阑珊处。"]},{"id":"chun-jiang-hua-yue-ye","title":"春江花月夜（节选）","author":"张若虚","dynasty":"唐代","type":"诗","isRequired":true,"text":["春江潮水连海平，","海上明月共潮生。","滟滟随波千万里，","何处春江无月明。","江流宛转绕芳甸，","月照花林皆似霰。","空里流霜不觉飞，","汀上白沙看不见。","江天一色无纤尘，","皎皎空中孤月轮。","江畔何人初见月？","江月何年初照人？","人生代代无穷已，","江月年年望相似。"]},{"id":"ke-zhi","title":"客至","author":"杜甫","dynasty":"唐代","type":"诗","isRequired":true,"text":["舍南舍北皆春水，","但见群鸥日日来。","花径不曾缘客扫，","蓬门今始为君开。","盘飧市远无兼味，","樽酒家贫只旧醅。","肯与邻翁相对饮，","隔篱呼取尽余杯。"]},{"id":"su-mu-zhe","title":"苏幕遮（燎沉香）","author":"周邦彦","dynasty":"宋代","type":"词","isRequired":true,"text":["燎沉香，消溽暑。","鸟雀呼晴，侵晓窥檐语。","叶上初阳干宿雨，","水面清圆，一一风荷举。","故乡遥，何日去？","家住吴门，久作长安旅。","五月渔郎相忆否？","小楫轻舟，梦入芙蓉浦。"]},{"id":"yi-ni-xing-lu-nan","title":"拟行路难（其四）","author":"鲍照","dynasty":"南北朝","type":"诗","isRequired":true,"text":["泻水置平地，","各自东西南北流。","人生亦有命，","安能行叹复坐愁？","酌酒以自宽，","举杯断绝歌路难。","心非木石岂无感？","吞声踯躅不敢言。"]},{"id":"lou-shi-ming","title":"陋室铭（节选）","author":"刘禹锡","dynasty":"唐代","type":"古文","isRequired":true,"text":["山不在高，有仙则名。","水不在深，有龙则灵。","斯是陋室，惟吾德馨。","苔痕上阶绿，草色入帘青。","谈笑有鸿儒，往来无白丁。","可以调素琴，阅金经。","无丝竹之乱耳，无案牍之劳形。","南阳诸葛庐，西蜀子云亭。","孔子云：何陋之有？"]},{"id":"ai-lian-shuo","title":"爱莲说（节选）","author":"周敦颐","dynasty":"宋代","type":"古文","isRequired":true,"text":["水陆草木之花，可爱者甚蕃。","晋陶渊明独爱菊。","自李唐来，世人甚爱牡丹。","予独爱莲之出淤泥而不染，","濯清涟而不妖，","中通外直，不蔓不枝，","香远益清，亭亭净植，","可远观而不可亵玩焉。"]},{"id":"pu-sa-man-shu-jiang","title":"菩萨蛮·书江西造口壁","author":"辛弃疾","dynasty":"宋代","type":"词","isRequired":true,"text":["郁孤台下清江水，","中间多少行人泪。","西北望长安，可怜无数山。","青山遮不住，毕竟东流去。","江晚正愁余，山深闻鹧鸪。"]},{"id":"deng-yue-yang-lou","title":"登岳阳楼","author":"杜甫","dynasty":"唐代","type":"诗","isRequired":true,"text":["昔闻洞庭水，","今上岳阳楼。","吴楚东南坼，","乾坤日夜浮。","亲朋无一字，","老病有孤舟。","戎马关山北，","凭轩涕泗流。"]},{"id":"yan-ge-xing","title":"燕歌行（节选）","author":"高适","dynasty":"唐代","type":"诗","isRequired":true,"text":["汉家烟尘在东北，","汉将辞家破残贼。","男儿本自重横行，","天子非常赐颜色。","战士军前半死生，","美人帐下犹歌舞。","大漠穷秋塞草腓，","孤城落日斗兵稀。","君不见沙场征战苦，","至今犹忆李将军。"]},{"id":"xiao-yao-you","title":"逍遥游（节选）","author":"庄子","dynasty":"先秦","type":"古文","isRequired":true,"text":["北冥有鱼，其名为鲲。","鲲之大，不知其几千里也。","化而为鸟，其名为鹏。","鹏之背，不知其几千里也。","怒而飞，其翼若垂天之云。","是鸟也，海运则将徙于南冥。","南冥者，天池也。"]},{"id":"tao-hua-yuan-ji","title":"桃花源记（节选）","author":"陶渊明","dynasty":"魏晋","type":"古文","isRequired":true,"text":["晋太元中，武陵人捕鱼为业。","缘溪行，忘路之远近。","忽逢桃花林，夹岸数百步，","中无杂树，芳草鲜美，落英缤纷。","林尽水源，便得一山，山有小口，仿佛若有光。","初极狭，才通人。复行数十步，豁然开朗。","土地平旷，屋舍俨然，有良田美池桑竹之属。","阡陌交通，鸡犬相闻。","黄发垂髫，并怡然自乐。"]}]